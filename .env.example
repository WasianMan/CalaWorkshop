# Copy to .env (compose reads it). Values below are placeholders.

# Existing Calagopus secrets — keep your real values, do NOT regenerate APP_ENCRYPTION_KEY.
POSTGRES_PASSWORD=change-me
APP_ENCRYPTION_KEY=keep-your-existing-value

# Shared bearer token between the panel extension and the workshop helper.
# Generate once: openssl rand -hex 32
# Paste the SAME value into the extension's admin settings as "Helper token".
WORKSHOP_HELPER_TOKEN=change-me
