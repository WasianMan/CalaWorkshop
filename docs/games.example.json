[
  {
    "app_id": 550,
    "name": "Left 4 Dead 2",
    "install_path": "left4dead2/addons",
    "auth": "account",
    "match": [
      { "glob": "*.vpk|*_legacy.bin", "rename": "{workshop_id}.vpk" },
      { "glob": "*_legacy.{jpg,jpeg,png}", "rename": "{workshop_id}.{ext}" }
    ],
    "generated_files": [],
    "scan": [
      { "path": "left4dead2/addons", "extensions": ["vpk", "jpg", "jpeg", "png"] },
      { "path": "left4dead2/addons/workshop", "extensions": ["vpk", "jpg", "jpeg", "png"] }
    ],
    "post_install": "none"
  },
  {
    "app_id": 4000,
    "name": "Garry's Mod",
    "install_path": "garrysmod",
    "auth": "anonymous",
    "match": [],
    "extract_files": [
      {
        "format": "gma",
        "glob": "*.gma|*_legacy.bin",
        "to": "addons/{title_slug}_{workshop_id}"
      }
    ],
    "generated_files": [
      {
        "path": "lua/autorun/server/cala_workshop_{workshop_id}.lua",
        "content": "if SERVER then resource.AddWorkshop(\"{workshop_id}\") end\n"
      }
    ],
    "scan": [
      { "path": "garrysmod/addons", "extensions": [] }
    ],
    "post_install": "none"
  },
  {
    "app_id": 107410,
    "name": "Arma 3",
    "install_path": "mods",
    "auth": "account",
    "match": [{ "glob": "**/*", "rename": "{basename}.{ext}" }],
    "post_install": "none"
  },
  {
    "app_id": 252490,
    "name": "Rust",
    "install_path": "server/rust/oxide/plugins",
    "auth": "anonymous",
    "match": [{ "glob": "*.cs" }],
    "post_install": "none"
  },
  {
    "app_id": 346110,
    "name": "ARK: Survival Evolved",
    "install_path": "ShooterGame/Content/Mods",
    "auth": "anonymous",
    "match": [{ "glob": "*.{zip,7z}", "rename": "{workshop_id}.{ext}" }],
    "post_install": "extract"
  }
]
